 *
 * Motor control DTS overlay examples
 * ===================================
 * Four complete hardware configurations demonstrating the
 * sensor + stage + controller node hierarchy:
 *
 *   Example 1 — PMSM FOC,        STM32G474,  quad encoder,  3-shunt ADC
 *   Example 2 — BLDC 6-step/FOC, STM32G474,  Hall × 3,      DC-link shunt
 *   Example 3 — DC brushed,      STM32G031,  quad encoder,  1-shunt ADC
 *   Example 4 — Stepper,         STM32F405,  step counter,  StallGuard
 */

/* ================================================================
 * Example 1 — PMSM FOC, STM32G474
 *   Sensor  : quadrature encoder TIM4, 3-shunt ADC1 HW-triggered
 *   Stage   : TIM1 3-phase complementary PWM, DRV8353 gate driver
 *   Algorithm: foc, 4 pole pairs, 20 kHz current loop
 * ================================================================ */
/ {
	pmsm0_sensor: motor-sensor-pmsm0 {
		compatible = "zephyr,motor-sensor-encoder";
		status     = "okay";

		encoder-timer = <&timers4>;
		encoder-cpr   = <4096>;       /* 1024 CPR × 4 quadrature   */
		pole-pairs    = <4>;

		index-gpio    = <&gpiob 6 GPIO_ACTIVE_HIGH>;

		io-channels      = <&adc1 1>, <&adc1 2>, <&adc1 3>;
		io-channel-names = "i_phase_a", "i_phase_b", "i_phase_c";

		/* STM32G4: TIM1 update event → ADC1 injected group trigger */
		adc-trigger-event = <0x00000001>;
	};

	pmsm0_stage: motor-stage-pmsm0 {
		compatible = "zephyr,motor-stage-3ph-inverter";
		status     = "okay";

		pwm-u = <&timers1>;           /* TIM1 CH1 / CH1N — phase U */
		pwm-v = <&timers1>;           /* TIM1 CH2 / CH2N — phase V */
		pwm-w = <&timers1>;           /* TIM1 CH3 / CH3N — phase W */

		pwm-frequency       = <20000>;
		deadtime-rising-ns  = <500>;
		deadtime-falling-ns = <500>;

		nfault-gpios = <&gpioa 7 (GPIO_ACTIVE_LOW  | GPIO_PULL_UP)>;
		en-gpios     = <&gpiob 0 GPIO_ACTIVE_HIGH>;
		sto-gpios    = <&gpioe 10 GPIO_ACTIVE_HIGH>,
		               <&gpioe 11 GPIO_ACTIVE_HIGH>;

		io-channels      = <&adc2 4>;
		io-channel-names = "v_bus";

		vbus-nominal-mv   = <24000>;
		vbus-ov-thresh-mv = <30000>;
		vbus-uv-thresh-mv = <18000>;
		i-peak-limit-ma   = <15000>;
	};

	pmsm0: motor-controller-pmsm0 {
		compatible = "zephyr,motor-controller";
		status     = "okay";

		sensor   = <&pmsm0_sensor>;
		actuator = <&pmsm0_stage>;

		algorithm  = "foc";
		pole-pairs = <4>;

		current-loop-rate-hz  = <20000>;
		speed-loop-rate-hz    = <1000>;
		position-loop-rate-hz = <200>;
		supervision-rate-hz   = <50>;

		i-max-ma              = <10000>;
		speed-max-rpm         = <3000>;
		temp-derating-start-dc = <8000>;
		temp-fault-dc          = <10000>;

		rs-mohm          = <85>;      /* 85 mΩ stator resistance   */
		ld-uh            = <540>;     /* 540 µH d-axis inductance  */
		lq-uh            = <620>;     /* 620 µH q-axis inductance  */
		flux-linkage-uwb = <12500>;   /* 12.5 mWb PM flux linkage  */
		pole-pairs       = <4>;

		settings-key = "motor/pmsm0";
	};
};

&timers1 {
	status = "okay";
	st,prescaler = <0>;
};

&timers4 {
	status = "okay";
	st,prescaler = <0>;
};

&adc1 {
	status = "okay";
	#io-channel-cells = <1>;
};

&adc2 {
	status = "okay";
	#io-channel-cells = <1>;
};


/* ================================================================
 * Example 2 — BLDC FOC with Hall sensors, STM32G474
 *   Sensor  : Hall × 3 on GPIOC[6:8], DC-link single shunt ADC1
 *   Stage   : TIM8 3-phase complementary PWM, DRV8302
 *   Algorithm: foc (or "6step" for trapezoidal), 7 pole pairs
 * ================================================================ */
/ {
	bldc0_sensor: motor-sensor-bldc0 {
		compatible = "zephyr,motor-sensor-hall";
		status     = "okay";

		hall-gpios = <&gpioc 6 GPIO_ACTIVE_HIGH>,   /* H_U */
		             <&gpioc 7 GPIO_ACTIVE_HIGH>,   /* H_V */
		             <&gpioc 8 GPIO_ACTIVE_HIGH>;   /* H_W */
		pole-pairs = <7>;

		io-channels      = <&adc1 5>;
		io-channel-names = "i_phase_a"; /* single shunt, Ib/Ic reconstructed */
		adc-trigger-event = <0x00000002>; /* TIM8_TRGO */
	};

	bldc0_stage: motor-stage-bldc0 {
		compatible = "zephyr,motor-stage-3ph-inverter";
		status     = "okay";

		pwm-u = <&timers8>;
		pwm-v = <&timers8>;
		pwm-w = <&timers8>;

		pwm-frequency       = <16000>;
		deadtime-rising-ns  = <750>;
		deadtime-falling-ns = <750>;

		nfault-gpios = <&gpiod 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		en-gpios     = <&gpiod 3 GPIO_ACTIVE_HIGH>;

		vbus-nominal-mv   = <24000>;
		vbus-ov-thresh-mv = <30000>;
		vbus-uv-thresh-mv = <18000>;
		i-peak-limit-ma   = <20000>;
	};

	bldc0: motor-controller-bldc0 {
		compatible = "zephyr,motor-controller";
		status     = "okay";

		sensor   = <&bldc0_sensor>;
		actuator = <&bldc0_stage>;

		algorithm  = "foc";         /* change to "6step" for trapezoidal */
		pole-pairs = <7>;

		current-loop-rate-hz  = <16000>;
		speed-loop-rate-hz    = <1000>;
		position-loop-rate-hz = <0>;    /* disabled — speed mode only */
		supervision-rate-hz   = <50>;

		i-max-ma      = <18000>;
		speed-max-rpm = <3000>;

		rs-mohm          = <120>;
		ld-uh            = <380>;
		lq-uh            = <380>;     /* isotropic SPM */
		flux-linkage-uwb = <9800>;

		settings-key = "motor/bldc0";
	};
};

&timers8 {
	status = "okay";
	st,prescaler = <0>;
};


/* ================================================================
 * Example 3 — DC brushed motor, STM32G031, H-bridge, DRV8833
 *   Sensor  : 500 CPR quad encoder TIM3, single inline shunt ADC1
 *   Stage   : TIM1 PWM left/right half-bridge, DRV8833
 *   Algorithm: openloop (or "foc" with pole-pairs=1)
 * ================================================================ */
/ {
	brushed0_sensor: motor-sensor-brushed0 {
		compatible = "zephyr,motor-sensor-encoder";
		status     = "okay";

		encoder-timer = <&timers3>;
		encoder-cpr   = <2000>;       /* 500 CPR × 4 quadrature    */
		pole-pairs    = <1>;          /* brushed: no Park transform */

		io-channels      = <&adc1 8>, <&adc1 9>;
		io-channel-names = "i_phase_a", "v_bus";
	};

	brushed0_stage: motor-stage-brushed0 {
		compatible = "zephyr,motor-stage-hbridge";
		status     = "okay";

		pwm-left  = <&pwm1 0 PWM_KHZ(20) PWM_POLARITY_NORMAL>;
		pwm-right = <&pwm1 1 PWM_KHZ(20) PWM_POLARITY_NORMAL>;

		nfault-gpios = <&gpioa 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		nsleep-gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>;

		pwm-frequency           = <20000>;
		deadtime-ns             = <0>;  /* DRV8833 handles dead-time */
		vbus-fault-threshold-mv = <15000>;
	};

	brushed0: motor-controller-brushed0 {
		compatible = "zephyr,motor-controller";
		status     = "okay";

		sensor   = <&brushed0_sensor>;
		actuator = <&brushed0_stage>;

		algorithm  = "openloop";
		pole-pairs = <1>;

		current-loop-rate-hz  = <20000>;
		speed-loop-rate-hz    = <1000>;
		position-loop-rate-hz = <200>;
		supervision-rate-hz   = <50>;

		i-max-ma      = <5000>;
		speed-max-rpm = <4000>;

		settings-key = "motor/brushed0";
	};
};

&timers3 {
	status = "okay";
	st,prescaler = <0>;
};


/* ================================================================
 * Example 4 — Stepper motor, STM32F405, TMC2209 (StallGuard)
 *   Sensor  : step counter + StallGuard DIAG (pseudo-current)
 *   Stage   : TIM2 step/dir PWM, dual H-bridge inside TMC2209
 *   Algorithm: stepdir, 50 pole pairs (1.8° stepper)
 * ================================================================ */
/ {
	stepper0_sensor: motor-sensor-stepper0 {
		compatible = "zephyr,motor-sensor-sensorless";
		status     = "okay";

		/* StallGuard DIAG output mapped as pseudo-current channel */
		io-channels      = <&adc1 10>;
		io-channel-names = "i_phase_a";

		pole-pairs    = <50>;         /* 1.8° stepper: 50 pole pairs */
		observer-type = "bemf-pu";    /* StallGuard uses BEMF loading */
		rs-mohm       = <500>;
		ld-uh         = <1500>;
		lq-uh         = <1500>;
	};

	stepper0_stage: motor-stage-stepper0 {
		compatible = "zephyr,motor-stage-hbridge";
		status     = "okay";

		/* STEP pulse via PWM; DIR via second PWM channel polarity */
		pwm-left  = <&pwm2 0 PWM_NSEC(500) PWM_POLARITY_NORMAL>;
		pwm-right = <&pwm2 1 PWM_NSEC(500) PWM_POLARITY_NORMAL>;

		nfault-gpios = <&gpiob 12 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		nsleep-gpios = <&gpiob 13 GPIO_ACTIVE_HIGH>;

		pwm-frequency           = <200000>; /* microstep clock ≤ 200 kHz */
		deadtime-ns             = <0>;
		vbus-fault-threshold-mv = <15000>;
	};

	stepper0: motor-controller-stepper0 {
		compatible = "zephyr,motor-controller";
		status     = "okay";

		sensor   = <&stepper0_sensor>;
		actuator = <&stepper0_stage>;

		algorithm  = "stepdir";
		pole-pairs = <50>;

		current-loop-rate-hz  = <200000>; /* microstep rate        */
		speed-loop-rate-hz    = <1000>;
		position-loop-rate-hz = <200>;
		supervision-rate-hz   = <50>;

		i-max-ma      = <1800>;
		speed-max-rpm = <600>;

		settings-key = "motor/stepper0";
	};
};
